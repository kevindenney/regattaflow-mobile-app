# RegattaFlow Environment Configuration
# Marine-grade sailing platform environment variables

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OAuth Configuration - Google
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id

# OAuth Configuration - Apple
EXPO_PUBLIC_APPLE_CLIENT_ID=regattaflow.app

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Google AI / Gemini Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key
EXPO_PUBLIC_GEMINI_API_KEY=your_google_ai_api_key

# Anthropic Claude Configuration (for Agent SDK)
ANTHROPIC_API_KEY=your_anthropic_api_key
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub Personal Access Token
# Used for repository operations (push, pull, workflow automation)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# Weather APIs
OPENWEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_KEY=your_weatherapi_key

# Marine Services
MARINE_TRAFFIC_API_KEY=your_marine_traffic_api_key
TIDAL_API_KEY=your_tidal_api_key

# Map Configuration
# MapTiler - get free key at https://www.maptiler.com/
EXPO_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
# Google Maps - get API key at https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_ios_api_key
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=your_google_maps_android_api_key

# Analytics and Monitoring
MIXPANEL_TOKEN=your_mixpanel_token
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn
# Sentry org/project for source map uploads (used by @sentry/react-native/expo plugin)
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Vercel Cron Authentication
# Random secret string used to authenticate Vercel Cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# Telegram Bot Configuration
# Create bot via @BotFather, set webhook to https://your-domain/api/telegram/webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername

# Development Settings
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_API_BASE_URL=https://api.regattaflow.app
EXPO_PUBLIC_WEB_BASE_URL=https://regattaflow.app

# Feature Flags
EXPO_PUBLIC_FEATURE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_FEATURE_OAUTH_LOGIN=true
EXPO_PUBLIC_FEATURE_OFFLINE_MODE=true
EXPO_PUBLIC_FEATURE_AI_STRATEGY=true
EXPO_PUBLIC_FEATURE_COACH_MARKETPLACE=true
