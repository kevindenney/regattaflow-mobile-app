+function formatSeasonForWidth(seasonLabel: string | undefined, windowWidth: number): string | undefined {
+  if (!seasonLabel) return undefined;
+  const normalized = seasonLabel.trim();
+  if (!normalized) return undefined;
+
+  const match = normalized.match(/^(Winter|Spring|Summer|Fall)\s+(\d{4})(?:-(\d{2,4}))?$/i);
+  const seasonWord = match?.[1];
+  const yearStart = match?.[2];
+  const yearEndRaw = match?.[3];
+  const yearEnd = yearEndRaw ? yearEndRaw.slice(-2) : undefined;
+  const yearStartShort = yearStart ? yearStart.slice(-2) : undefined;
+
+  if (windowWidth >= 1260) {
+    return normalized;
+  }
+
+  if (windowWidth >= 980) {
+    if (seasonWord && yearStartShort && yearEnd) {
+      return `${seasonWord} ${yearStartShort}-${yearEnd}`;
+    }
+    return normalized.length > 16 ? `${normalized.slice(0, 16)}…` : normalized;
+  }
+
+  if (seasonWord && yearStartShort && yearEnd) {
+    return `${seasonWord[0].toUpperCase()}${yearStartShort}-${yearEnd}`;
+  }
+
+  return normalized.length > 10 ? `${normalized.slice(0, 10)}…` : normalized;
+}
